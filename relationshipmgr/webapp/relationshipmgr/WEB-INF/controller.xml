<?xml version="1.0" encoding="UTF-8"?>
<site-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://ofbiz.apache.org/Site-Conf" xsi:schemaLocation="http://ofbiz.apache.org/Site-Conf http://ofbiz.apache.org/dtds/site-conf.xsd">
    <include location="component://common/webcommon/WEB-INF/common-controller.xml"/>

    <description>Relationshipmgr Component Site Configuration File</description>

    <!-- Request Mappings -->
    <request-map uri="main">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="main"/>
    </request-map>

    <request-map uri="AddPersonScreen">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="AddPersonScreen"/>
    </request-map>

    <request-map uri="AddOrganizationScreen">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="AddOrganizationScreen"/>
    </request-map>

    <request-map uri="viewPartyDetails">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="viewPartyDetails"/>
    </request-map>

    <!-- Service Invocation Mappings -->
    <request-map uri="createPerson">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPersonWithParty"/>
        <response name="success" type="request-redirect" value="viewPartyDetails">
            <redirect-parameter name="partyId"/>
        </response>
        <response name="error" type="view" value="AddPersonScreen"/>
    </request-map>

    <request-map uri="createOrganization">
        <security https="true" auth="true"/>
        <event type="service" invoke="createOrganizationWithParty"/>
        <response name="success" type="request-redirect" value="viewPartyDetails">
            <redirect-parameter name="partyId"/>
        </response>
        <response name="error" type="view" value="AddOrganizationScreen"/>
    </request-map>

    <request-map uri="createTelecom">
        <security https="true" auth="true"/>
        <event type="service" invoke="createTelecomNumberWithContact"/>
        <response name="success" type="request-redirect" value="viewPartyDetails">
            <redirect-parameter name="partyId"/>
        </response>
        <response name="error" type="view" value="viewPartyDetails"/>
    </request-map>

    <request-map uri="createPostal">
        <security https="true" auth="true"/>
        <event type="service" invoke="createPostalAddressWithContact"/>
        <response name="success" type="request-redirect" value="viewPartyDetails">
            <redirect-parameter name="partyId"/>
        </response>
        <response name="error" type="view" value="viewPartyDetails"/>
    </request-map>

    <request-map uri="createEmail">
        <security https="true" auth="true"/>
        <event type="service" invoke="createEmailWithContact"/>
        <response name="success" type="request-redirect" value="viewPartyDetails">
            <redirect-parameter name="partyId"/>
        </response>
        <response name="error" type="view" value="viewPartyDetails"/>
    </request-map>

    <!-- View Mappings -->
    <view-map name="main" type="screen" page="component://relationshipmgr/widget/RelationshipmgrScreens.xml#main"/>
    <view-map name="AddPersonScreen" type="screen" page="component://relationshipmgr/widget/RelationshipmgrScreens.xml#AddPersonScreen"/>
    <view-map name="AddOrganizationScreen" type="screen" page="component://relationshipmgr/widget/RelationshipmgrScreens.xml#AddOrganizationScreen"/>
    <view-map name="viewPartyDetails" type="screen" page="component://relationshipmgr/widget/RelationshipmgrScreens.xml#viewPartyDetails"/>

</site-conf>