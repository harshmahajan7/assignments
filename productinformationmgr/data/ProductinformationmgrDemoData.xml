    <!-- PRODUCT ASSOCIATIONS                                         -->
    <!-- ============================================================ -->

    <!-- Smartphone virtual → variants -->
    <PimProductAssoc productId="PROD10000" toProductId="PROD10001"
        productAssocTypeId="PRODUCT_VARIANT" fromDate="2023-01-01 00:00:00.000" />
