    <PimProductFeature productFeatureId="FEAT_COLOR_RED" productFeatureTypeId="COLOR"
        description="Red" />
    <PimProductFeature productFeatureId="FEAT_COLOR_WHITE" productFeatureTypeId="COLOR"
        description="White" />

    <!-- Storage -->
    <PimProductFeature productFeatureId="FEAT_STG_64GB" productFeatureTypeId="STORAGE"
        description="64 GB" />
    <PimProductFeature productFeatureId="FEAT_STG_128GB" productFeatureTypeId="STORAGE"
        description="128 GB" />
    <PimProductFeature productFeatureId="FEAT_STG_256GB" productFeatureTypeId="STORAGE"
        description="256 GB" />
    <PimProductFeature productFeatureId="FEAT_STG_512GB" productFeatureTypeId="STORAGE"
        description="512 GB" />

    <!-- RAM -->
    <PimProductFeature productFeatureId="FEAT_RAM_8GB" productFeatureTypeId="RAM"
        description="8 GB RAM" />
    <PimProductFeature productFeatureId="FEAT_RAM_16GB" productFeatureTypeId="RAM"
        description="16 GB RAM" />

    <!-- Size (clothing kept for existing data) -->
    <PimProductFeature productFeatureId="FEAT_SIZE_64GB" productFeatureTypeId="SIZE"
        description="64 GB" />
    <PimProductFeature productFeatureId="FEAT_SIZE_128GB" productFeatureTypeId="SIZE"
        description="128 GB" />

