    <PimProductCategoryMember productCategoryId="CAT_MOBILES" productId="PROD_IPHONE13"
        fromDate="2024-01-01 00:00:00.000" />
    <PimProductCategoryMember productCategoryId="CAT_LAPTOPS" productId="PROD_MACBOOK"
