    <!-- Smartphone — Variants -->
    <PimProduct productId="PROD10001" productTypeId="FINISHED_GOOD" productName="Smartphone-128GB"
        isVirtual="N" isVariant="Y" fromDate="2023-01-01 00:00:00.000" />
    <PimProduct productId="PROD10002" productTypeId="FINISHED_GOOD" productName="Smartphone-256GB"
        isVirtual="N" isVariant="Y" fromDate="2023-01-01 00:00:00.000" />

    <!-- Laptop — Virtual parent -->
    <PimProduct productId="PROD20000" productTypeId="FINISHED_GOOD" productName="Laptop"
        isVirtual="Y" isVariant="N" fromDate="2023-09-01 00:00:00.000" />
