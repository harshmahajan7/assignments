<entity-engine-xml>

    <!-- ============================================================ -->
    <!-- REFERENCE / TYPE DATA                                        -->
    <!-- ============================================================ -->

    <!-- Product Types -->
    <PimProductType productTypeId="FINISHED_GOOD" description="Finished Good" />
    <PimProductType productTypeId="DIGITAL_GOOD" description="Digital Good" />
    <PimProductType productTypeId="MARKETING_PKG" description="Marketing Package" />

    <!-- Product Content Types -->
    <PimProductContentType productContentTypeId="IMAGE" description="Image" />
    <PimProductContentType productContentTypeId="DESCRIPTION" description="Description" />

    <!-- Product Price Types -->
    <PimProductPriceType productPriceTypeId="LIST_PRICE" description="List Price" />
    <PimProductPriceType productPriceTypeId="PROMO_PRICE" description="Promotional Price" />

    <!-- Units of Measure (weight / length / currency) -->
    <PimUom uomId="WT_oz" description="Weight in ounces" />
    <PimUom uomId="WT_lbs" description="Weight in pounds" />
    <PimUom uomId="WT_g" description="Weight in grams" />
    <PimUom uomId="WT_kg" description="Weight in kilograms" />
    <PimUom uomId="LEN_in" description="Length in inches" />
    <PimUom uomId="LEN_cm" description="Length in centimeters" />
    <PimUom uomId="USD" description="US Dollar" />

    <!-- Dimension Types -->
    <PimDimensionType dimensionTypeId="WEIGHT" description="Weight" />
    <PimDimensionType dimensionTypeId="LENGTH" description="Length" />
    <PimDimensionType dimensionTypeId="WIDTH" description="Width" />
    <PimDimensionType dimensionTypeId="HEIGHT" description="Height" />

    <!-- Product Association Types -->
    <PimProductAssocType productAssocTypeId="PRODUCT_VARIANT" description="Product Variant" />
    <PimProductAssocType productAssocTypeId="PRODUCT_COMP" description="Product Component" />
    <PimProductAssocType productAssocTypeId="CROSS_SELL" description="Cross Sell" />
    <PimProductAssocType productAssocTypeId="UP_SELL" description="Up Sell" />

    <!-- Good Identification Types -->
    <PimGoodIdentificationType goodIdentificationTypeId="SKU" description="Stock Keeping Unit" />
    <PimGoodIdentificationType goodIdentificationTypeId="UPCA" description="UPC-A" />
    <PimGoodIdentificationType goodIdentificationTypeId="ISBN" description="ISBN" />
    <PimGoodIdentificationType goodIdentificationTypeId="INTERNAL" description="Internal Code" />

    <!-- Product Feature Types -->
    <PimProductFeatureType productFeatureTypeId="COLOR" description="Color" />
    <PimProductFeatureType productFeatureTypeId="SIZE" description="Size" />
    <PimProductFeatureType productFeatureTypeId="STORAGE" description="Storage Capacity" />
    <PimProductFeatureType productFeatureTypeId="RAM" description="RAM" />

    <!-- Product Category Types -->
    <PimProductCategoryType productCategoryTypeId="CATALOG" description="Catalog Category" />
    <PimProductCategoryType productCategoryTypeId="SEARCH" description="Search Category" />

    <!-- ============================================================ -->
    <!-- PRODUCT CATEGORIES  (Taxonomy)                              -->
    <!-- ============================================================ -->

    <PimProductCategory productCategoryId="CAT_ROOT" categoryName="All Products" />
    <PimProductCategory productCategoryId="CAT_ELECTRONICS" primaryParentCategoryId="CAT_ROOT"
        categoryName="Electronics" />
    <PimProductCategory productCategoryId="CAT_MOBILES" primaryParentCategoryId="CAT_ELECTRONICS"
        categoryName="Mobile Phones" />
    <PimProductCategory productCategoryId="CAT_LAPTOPS" primaryParentCategoryId="CAT_ELECTRONICS"
        categoryName="Laptops" />
    <PimProductCategory productCategoryId="CAT_BUNDLES" primaryParentCategoryId="CAT_ROOT"
        categoryName="Bundles &amp; Packages" />

    <!-- Category Rollups -->
    <PimProductCategoryRollup productCategoryId="CAT_ELECTRONICS" parentProductCategoryId="CAT_ROOT"
        fromDate="2023-01-01 00:00:00.000" />
    <PimProductCategoryRollup productCategoryId="CAT_MOBILES"
        parentProductCategoryId="CAT_ELECTRONICS" fromDate="2023-01-01 00:00:00.000" />
