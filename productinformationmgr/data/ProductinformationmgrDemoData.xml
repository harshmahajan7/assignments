    <!-- PRODUCT DIMENSIONS                                           -->
    <!-- ============================================================ -->

    <PimProductDimension productId="PROD10000" dimensionTypeId="WEIGHT" dimensionValue="6.60"
        uomId="WT_oz" />
    <PimProductDimension productId="PROD10001" dimensionTypeId="WEIGHT" dimensionValue="2.5"
        uomId="WT_lbs" />
