    <!-- Request Mappings -->
    <request-map uri="main"><security https="true" auth="true"/><response name="success" type="request" value="FindOmsOrderHeader"/></request-map>

    <!-- Order Header -->
    <request-map uri="FindOmsOrderHeader">
        <security https="true" auth="true"/>
        <response name="success" type="view" value="FindOmsOrderHeader"/>
    </request-map>
    <request-map uri="EditOmsOrderHeader">
