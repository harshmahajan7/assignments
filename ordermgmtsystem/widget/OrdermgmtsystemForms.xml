    <!-- ============================================================ -->

    <form name="FindOmsOrderHeader" type="single" target="FindOmsOrderHeader" default-entity-name="OmsOrderHeader">
        <auto-fields-entity entity-name="OmsOrderHeader" default-field-type="find"/>
        <field name="noConditionFind"><hidden value="Y"/></field>
        <field name="searchButton" title="Search"><submit button-type="button"/></field>
    </form>

    <form name="ListOmsOrderHeaders" type="list" list-name="listIt" paginate-target="FindOmsOrderHeader"
            default-entity-name="OmsOrderHeader" separate-columns="true"
            odd-row-style="alternate-row" header-row-style="header-row-2" default-table-style="basic-table hover-bar">
        <actions>
            <service service-name="performFind" result-map="result" result-map-list="listIt">
                <field-map field-name="inputFields" from-field="parameters"/>
                <field-map field-name="entityName" value="OmsOrderHeader"/>
                <field-map field-name="orderBy" value="-orderDate"/>
                <field-map field-name="viewIndex" from-field="viewIndex"/>
                <field-map field-name="viewSize" from-field="viewSize"/>
            </service>
        </actions>
        <auto-fields-entity entity-name="OmsOrderHeader" default-field-type="display"/>
        <field name="orderId" title="Order ID" widget-style="buttontext">
            <hyperlink description="${orderId}" target="EditOmsOrderHeader" also-hidden="false">
                <parameter param-name="orderId"/>
            </hyperlink>
        </field>
        <field name="orderTypeId" title="Type">
            <display-entity entity-name="OmsOrderType" key-field-name="orderTypeId" description="${description}"/>
        </field>
        <field name="statusId" title="Status">
            <display-entity entity-name="OmsOrderStatusType" key-field-name="statusId" description="${description}"/>
        </field>
        <field name="deleteLink" title=" " widget-style="buttontext">
            <hyperlink description="Delete" target="deleteOmsOrderHeader" also-hidden="false">
                <parameter param-name="orderId"/>
            </hyperlink>
        </field>
    </form>

    <form name="EditOmsOrderHeader" type="single" target="updateOmsOrderHeader"
            default-entity-name="OmsOrderHeader" default-map-name="omsOrderHeader">
        <alt-target use-when="omsOrderHeader==null" target="createOmsOrderHeader"/>
        <auto-fields-entity entity-name="OmsOrderHeader" default-field-type="edit"/>
        <field name="orderId" use-when="omsOrderHeader!=null" title="Order ID"><display/></field>
        <field name="orderId" use-when="omsOrderHeader==null" title="Order ID"><text/></field>
        <field name="orderTypeId" title="Order Type">
            <drop-down allow-empty="true">
                <entity-options entity-name="OmsOrderType" key-field-name="orderTypeId" description="${description} [${orderTypeId}]"/>
            </drop-down>
        </field>
        <field name="statusId" title="Status">
            <drop-down allow-empty="true">
                <entity-options entity-name="OmsOrderStatusType" key-field-name="statusId" description="${description} [${statusId}]"/>
            </drop-down>
        </field>
        <field name="placedByPartyId" title="Placed By">
            <drop-down allow-empty="true">
                <entity-options entity-name="OmsParty" key-field-name="partyId" description="${partyName} [${partyId}]"/>
            </drop-down>
        </field>
        <field name="orderDate" title="Order Date"><date-time type="timestamp"/></field>
        <field name="currencyUomId" title="Currency"><text/></field>
        <field name="grandTotal" title="Grand Total"><text/></field>
        <field name="submitButton" title="Save"><submit button-type="button"/></field>
    </form>

